{
  "manifest_version": 3,
  "name": "AIMirror - Instagram Behavioral Tracker",
  "version": "1.0.0",
  "description": "Track your Instagram Reels behavior for transparency and self-awareness",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
